<style>
/* ====== VARIABLES ====== */
:root{
  --ink:#0f1e3c; --ink2:#1a3255; --paper:#faf8f4; --warm:#f5f0e8;
  --rule:#d4cbb8; --accent:#9b1b4b; --blue:#1a4f8a; --green:#145f3a;
  --gold:#c9870c; --purple:#5c2d8e; --orange:#b94a00;
  --proof-bg:#edf6fb; --proof-bd:#1e7abf;
  --form-bg:#fef9e7; --form-bd:#d4890a;
  --ex-bg:#f0fdf4; --ex-bd:#1a8a4a;
  --pr-bg:#fdf3ff; --pr-bd:#7e22ce;
  --tip-bg:#f0f9ff; --tip-bd:#0284c7;
  --warn-bg:#fff1f2; --warn-bd:#be123c;
  --exam-bg:#fff8f0; --exam-bd:#b94a00;
  --serif:'Noto Serif JP',Georgia,serif;
  --sans:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;
}
/* ====== RESET ====== */
*{box-sizing:border-box;margin:0;padding:0;}html,body{overflow-x:hidden;max-width:100%;}
html{font-size:15px;}
body{font-family:'Noto Serif JP',Georgia,serif;background:#faf8f4;color:#0f1e3c;line-height:1.9;}
p{margin-bottom:11px;}
strong{font-weight:700;}
/* ====== PAGE / PRINT ====== */
@page{size:A4;margin:18mm 16mm 18mm 16mm;}
@media print{
html{font-size:11px;}
body{background:#fff;}
nav,.no-print,.back-to-top{display:none!important;}
.main-content{margin-left:0!important;}
.chapter{page-break-before:always;padding:0 0 24px;}
.chapter:first-of-type{page-break-before:avoid;}
.print-cover{display:flex!important;page-break-after:always;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
.toc-section{page-break-after:always;}
.formula-box,.proof-box,.example-box,.exercise-block,.exam-card,.tip-box,.important-box{page-break-inside:avoid;break-inside:avoid;}
.section{page-break-inside:auto;}
h3,h4{page-break-after:avoid;}
.answer-block{page-break-inside:avoid;break-inside:avoid;}
table{page-break-inside:avoid;break-inside:avoid;}
.two-col,.three-col{page-break-inside:avoid;}
a{color:inherit;text-decoration:none;}
.chapter-header{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
.formula-box,.proof-box,.example-box,.exercise-block,.tip-box,.important-box{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
.formula-box::before,.proof-box::before,.example-box::before,.exercise-block::before,.tip-box::before,.important-box::before{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
.exam-hd{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
th{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
.MathJax{font-size:100%!important;}
}
@media screen{.print-cover{display:none;}}
/* ====== PRINT COVER ====== */
.print-cover{background:linear-gradient(135deg,#0f1e3c 0%,#1a3255 55%,#1a4f8a 100%);color:#fff;min-height:100vh;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:80px 56px;}
.print-cover h1{font-size:3.2rem;font-weight:300;letter-spacing:0.12em;margin-bottom:10px;}
.print-cover h1 span{font-weight:700;color:#f0c040;}
.print-cover .cv-sub{font-size:1rem;opacity:.65;letter-spacing:.3em;margin-bottom:44px;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;}
.print-cover .cv-chs{display:flex;flex-wrap:wrap;gap:9px;justify-content:center;margin-bottom:44px;}
.print-cover .cv-ch{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);padding:5px 16px;border-radius:20px;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:13px;}
.print-cover .cv-note{font-size:11.5px;opacity:.45;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;border-top:1px solid rgba(255,255,255,.12);padding-top:20px;letter-spacing:.1em;}
/* ====== NAV TOGGLE BUTTON ====== */
#nav-toggle-btn{position:fixed;top:13px;left:14px;z-index:400;background:#0f1e3c;color:#f0c040;border:1.5px solid rgba(240,192,64,.4);padding:7px 15px 7px 11px;border-radius:7px;cursor:pointer;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:12.5px;font-weight:700;letter-spacing:.04em;display:flex;align-items:center;gap:8px;box-shadow:0 2px 14px rgba(0,0,0,.4);transition:background .2s;user-select:none;}
#nav-toggle-btn:hover{background:#1a3255;}
#nav-toggle-btn .tgl-icon{font-size:17px;line-height:1;transition:transform .38s cubic-bezier(.4,0,.2,1);display:inline-block;}
#nav-toggle-btn.open .tgl-icon{transform:rotate(90deg);}
/* ====== NAV ====== */
nav{position:fixed;top:0;left:0;width:100%;max-height:0;overflow:hidden;transition:max-height .45s cubic-bezier(.4,0,.2,1);background:#0f1e3c;color:#ccc;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:11.5px;z-index:350;box-shadow:0 6px 36px rgba(0,0,0,.5);}
nav.nav-open{max-height:82vh;overflow-y:auto;}
.nav-inner{padding:56px 24px 24px;display:flex;flex-wrap:wrap;align-items:flex-start;gap:0 28px;}
.nav-col{flex:0 0 auto;min-width:158px;max-width:210px;margin-bottom:12px;}
.nav-title{color:#fff;font-weight:700;font-size:13px;padding:0 0 9px;border-bottom:1px solid rgba(255,255,255,.12);margin-bottom:6px;letter-spacing:.06em;display:block;}
nav a{display:block;color:#8ab;text-decoration:none;padding:3px 0 3px 8px;transition:all .18s;border-left:2px solid transparent;}
nav a:hover{color:#fff;border-left-color:#f0c040;padding-left:14px;}
.nav-ch{color:#f0c040;font-weight:700;margin-top:10px;margin-bottom:3px;font-size:11px;letter-spacing:.06em;}
.nav-col .nav-ch:first-child{margin-top:0;}
.nav-sub{font-size:10.5px;color:#678;padding-left:14px!important;}
.nav-sub:hover{color:#acd;}
#nav-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.38);z-index:200;}
#nav-overlay.active{display:block;}
/* ====== SYM TOOLTIP ====== */
.sym-tip{position:relative;display:inline;cursor:help;border-bottom:1px dashed rgba(26,79,138,.55);}
.sym-tip::after{content:attr(data-tip);position:absolute;bottom:calc(100% + 7px);left:50%;transform:translateX(-50%);background:#1a3255;color:#ddeeff;font-size:11px;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-weight:400;line-height:1.6;padding:5px 10px;border-radius:6px;white-space:nowrap;box-shadow:0 3px 14px rgba(0,0,0,.35);opacity:0;pointer-events:none;transition:opacity .18s;z-index:500;}
.sym-tip::before{content:'';position:absolute;bottom:calc(100% + 2px);left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:#1a3255;opacity:0;pointer-events:none;transition:opacity .18s;z-index:500;}
.sym-tip:hover::after,.sym-tip:hover::before{opacity:1;}
/* Symbol guide */
#sym-guide-btn{position:fixed;bottom:80px;right:24px;z-index:150;background:#1a4f8a;color:#fff;border:none;width:44px;height:44px;border-radius:50%;cursor:pointer;font-size:19px;box-shadow:0 2px 12px rgba(0,0,0,.3);transition:transform .2s,background .2s;display:flex;align-items:center;justify-content:center;}
#sym-guide-btn:hover{background:#0f1e3c;transform:scale(1.1);}
#sym-guide-panel{position:fixed;bottom:134px;right:24px;z-index:150;width:330px;max-height:430px;overflow-y:auto;background:#fff;border:1.5px solid #d4cbb8;border-radius:10px;box-shadow:0 8px 36px rgba(0,0,0,.18);font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:12px;line-height:1.7;display:none;}
#sym-guide-panel.open{display:block;}
.sg-hd{background:#0f1e3c;color:#fff;padding:10px 16px;border-radius:8px 8px 0 0;font-weight:700;font-size:13px;letter-spacing:.04em;display:flex;align-items:center;justify-content:space-between;}
.sg-hd button{background:none;border:none;color:#aaa;cursor:pointer;font-size:18px;line-height:1;padding:0;}
.sg-hd button:hover{color:#fff;}
.sg-body{padding:12px 14px;}
.sg-sec{margin-bottom:14px;}
.sg-sec-title{color:#1a4f8a;font-size:11px;font-weight:700;letter-spacing:.08em;border-bottom:1px solid #e0dbd0;padding-bottom:4px;margin-bottom:6px;}
.sg-row{display:grid;grid-template-columns:44px 82px 1fr;gap:4px;align-items:baseline;padding:2px 0;}
.sg-sym{font-size:15px;color:#0f1e3c;font-weight:700;}
.sg-read{color:#9b1b4b;font-size:11px;}
.sg-mean{color:#444;font-size:10.5px;}
/* ====== LAYOUT ====== */
.main-content{margin-left:0;width:100%;overflow-x:hidden;}
/* ====== HEADER ====== */
.header-banner{background:linear-gradient(135deg,#0f1e3c 0%,#1a3255 50%,#16325e 100%);color:#fff;padding:40px 40px 34px;position:relative;overflow:hidden;}
.header-banner::before{content:'';position:absolute;top:-50px;right:-50px;width:280px;height:280px;border:1px solid rgba(255,255,255,.04);border-radius:50%;}
.header-banner h1{font-size:2.5em;font-weight:300;letter-spacing:.08em;margin-bottom:8px;}
.header-banner h1 span{font-weight:700;color:#f0c040;}
.header-banner p{color:rgba(255,255,255,.55);font-size:13px;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;}
.hd-badges{display:flex;flex-wrap:wrap;gap:7px;margin-top:18px;}
.hd-badge{background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.14);color:rgba(255,255,255,.75);padding:3px 11px;border-radius:16px;font-size:12px;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;}
/* ====== TOC ====== */
.toc-section{padding:36px 40px;border-bottom:2px solid #d4cbb8;}
.toc-section h2{font-size:1.6em;margin-bottom:24px;border-bottom:2px solid #0f1e3c;padding-bottom:9px;}
.toc-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;}
.toc-card{border:1.5px solid #d4cbb8;border-radius:8px;padding:16px;text-decoration:none;color:inherit;display:block;transition:all .2s;}
.toc-card:hover{border-color:#1a4f8a;transform:translateY(-2px);box-shadow:0 4px 14px rgba(0,0,0,.08);}
.toc-num{font-size:10.5px;color:#9b1b4b;font-weight:700;letter-spacing:.1em;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;}
.toc-title{font-size:1.15em;font-weight:700;margin:4px 0 8px;}
.toc-topics{font-size:11.5px;color:#666;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;line-height:1.7;}
/* ====== CHAPTER ====== */
.chapter{padding:0 40px 40px;border-bottom:2px solid #d4cbb8;}
.chapter-header{padding:42px 0 24px;border-bottom:3px solid #0f1e3c;margin-bottom:28px;}
.ch-num{font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:11px;font-weight:600;color:#9b1b4b;letter-spacing:.18em;text-transform:uppercase;margin-bottom:6px;}
.chapter-header h2{font-size:2em;font-weight:600;letter-spacing:.03em;line-height:1.3;}
.chapter-header p{margin-top:9px;color:#555;font-size:13.5px;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;max-width:640px;}
/* ====== SECTIONS ====== */
.section{margin-bottom:38px;}
h3{font-size:1.2em;font-weight:700;color:#1a4f8a;border-left:4px solid #1a4f8a;padding-left:12px;margin:30px 0 14px;}
h4{font-size:1.02em;font-weight:700;color:#0f1e3c;margin:18px 0 9px;padding-bottom:3px;border-bottom:1px dashed #d4cbb8;}
.section-sep{border:none;border-top:1px dashed #d4cbb8;margin:22px 0;}
/* ====== BOXES ====== */
.formula-box,.proof-box,.example-box,.exercise-block,.tip-box,.exam-card,.important-box{border-radius:7px;padding:18px 22px;margin:16px 0;position:relative;}
.formula-box{background:#fef9e7;border:1.5px solid #d4890a;border-left:5px solid #d4890a;}
.formula-box::before{content:'公式';position:absolute;top:-10px;left:14px;background:#d4890a;color:#fff;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:10px;font-weight:700;padding:2px 8px;border-radius:3px;letter-spacing:.08em;}
.formula-box.theorem::before{content:'定理';background:#1a4f8a;}
.formula-box.definition::before{content:'定義';background:#9b1b4b;}
.formula-box.important::before{content:'重要';background:#b91c1c;}
.proof-box{background:#edf6fb;border:1.5px solid #1e7abf;border-left:5px solid #1e7abf;}
.proof-box::before{content:'導出';position:absolute;top:-10px;left:14px;background:#1e7abf;color:#fff;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:10px;font-weight:700;padding:2px 8px;border-radius:3px;}
.proof-box .qed{text-align:right;font-size:16px;color:#1e7abf;margin-top:6px;}
.example-box{background:#f0fdf4;border:1.5px solid #1a8a4a;border-left:5px solid #1a8a4a;}
.example-box::before{content:'例題';position:absolute;top:-10px;left:14px;background:#1a8a4a;color:#fff;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:10px;font-weight:700;padding:2px 8px;border-radius:3px;}
.exercise-block{background:#fdf3ff;border:1.5px solid #7e22ce;border-left:5px solid #7e22ce;}
.exercise-block::before{content:'練習';position:absolute;top:-10px;left:14px;background:#7e22ce;color:#fff;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:10px;font-weight:700;padding:2px 8px;border-radius:3px;}
.tip-box{background:#f0f9ff;border:1.5px solid #0284c7;border-left:5px solid #0284c7;}
.tip-box::before{content:'POINT';position:absolute;top:-10px;left:14px;background:#0284c7;color:#fff;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:10px;font-weight:700;padding:2px 8px;border-radius:3px;letter-spacing:.06em;}
.important-box{background:#fff1f2;border:1.5px solid #be123c;border-left:5px solid #be123c;}
.important-box::before{content:'注意';position:absolute;top:-10px;left:14px;background:#be123c;color:#fff;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:10px;font-weight:700;padding:2px 8px;border-radius:3px;}
.exam-card{border:2px solid #1a3255;border-radius:8px;overflow:hidden;margin:18px 0;background:#fff;}
.exam-hd{background:linear-gradient(90deg,#0f1e3c,#1a3255);color:#fff;padding:10px 17px;display:flex;justify-content:space-between;align-items:center;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:13px;font-weight:600;}
.exam-body{padding:18px 20px;}
.etag{font-size:10.5px;padding:2px 8px;border-radius:10px;font-weight:700;}
.tag-mec{background:#fde68a;color:#78350f;}
.tag-elec{background:#bfdbfe;color:#1e3a8a;}
.tag-therm{background:#fca5a5;color:#7f1d1d;}
.tag-wave{background:#a7f3d0;color:#064e3b;}
.tag-atom{background:#ddd6fe;color:#4c1d95;}
/* ====== ANSWER BLOCK ====== */
.answer-block{background:#fefefe;border:1px dashed #aaa;border-radius:6px;padding:13px 17px;margin-top:12px;}
.answer-block::before{content:'解答';font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:10px;font-weight:700;color:#777;display:block;margin-bottom:5px;letter-spacing:.1em;}
/* ====== TABLE ====== */
.table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;width:100%;margin:14px 0;}
table{border-collapse:collapse;width:100%;font-size:13px;border:1px solid #b0a090;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;min-width:auto;}
th{background:#0f1e3c;color:#fff;padding:8px 12px;text-align:center;font-weight:500;letter-spacing:.04em;}
td{padding:7px 12px;border:1px solid #b0a090;text-align:center;vertical-align:middle;}
tr:nth-child(even) td{background:#f5f0e8;}
/* ====== GRID ====== */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:12px 0;}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin:12px 0;}
@media(max-width:700px){.two-col,.three-col{grid-template-columns:1fr;}}
.sum-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;margin:14px 0;}
.sum-card{background:#fff;border:1.5px solid #d4cbb8;border-radius:8px;padding:14px 16px;}
.sum-card h4{font-size:13px;margin-bottom:7px;border:none;padding:0;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;}
.sum-card p{font-size:12.5px;color:#444;margin:0;line-height:1.7;}
/* ====== MISC ====== */
.hl{background:#fef3d0;padding:1px 3px;border-radius:2px;}
.red{color:#b91c1c;font-weight:700;}
.blue{color:#1a4f8a;font-weight:700;}
.green{color:#145f3a;font-weight:700;}
.note{background:#f8f9fa;border-left:4px solid #adb5bd;padding:10px 15px;margin:12px 0;font-size:13px;color:#555;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;border-radius:0 5px 5px 0;}
.lv{font-size:10px;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-weight:700;letter-spacing:.06em;padding:2px 7px;border-radius:9px;margin-left:7px;vertical-align:middle;}
.lv-b{background:#d1fae5;color:#065f46;}
.lv-m{background:#fef9c3;color:#713f12;}
.lv-a{background:#fce7f3;color:#9d174d;}
.lv-e{background:#ede9fe;color:#4c1d95;}
ul.bullet,ol.num{padding-left:22px;margin:9px 0;}
ul.bullet li,ol.num li{margin-bottom:5px;line-height:1.85;}
ol.steps{padding-left:26px;margin:9px 0;}
ol.steps li{margin-bottom:6px;line-height:1.85;font-family:'Noto Sans JP','Hiragino Kaku Gothic Pro',sans-serif;font-size:13.5px;}
.back-to-top{position:fixed;bottom:26px;right:26px;background:#0f1e3c;color:#fff;width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:17px;box-shadow:0 2px 12px rgba(0,0,0,.3);transition:transform .2s;z-index:99;}
.back-to-top:hover{transform:translateY(-3px);}
</style>

</head>
