<math display="block" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><msub><mi>K</mi><mi>w</mi></msub><mrow><mo stretchy="true" form="prefix">(</mo><mtext mathvariant="normal">25°C</mtext><mo stretchy="true" form="postfix">)</mo></mrow><mo>=</mo><mn>1.0</mn><mo>×</mo><msup><mn>10</mn><mrow><mo>−</mo><mn>14</mn></mrow></msup><mspace width="1.0em"></mspace><mtext mathvariant="normal">標準モル体積</mtext><mo>=</mo><mn>22.4</mn><mspace width="0.167em"></mspace><mtext mathvariant="normal">L/mol（0°C, 1 atm）</mtext></mrow><annotation encoding="application/x-tex">K_w(\text{25°C}) = 1.0\times10^{-14}\quad\text{標準モル体積} = 22.4\,\text{L/mol（0°C, 1 atm）}</annotation></semantics></math>
