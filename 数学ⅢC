  ['∃', '存在量化子：「〜が存在して」（there exists）'],
  ['⇒', '含意：「ならば」（implies）'],
  ['⟺', '同値：「必要十分条件」（if and only if）'],
  ['∈', '帰属：「〜は〜の元（要素）である」（belongs to）'],
  ['⊂', '包含：「〜の部分集合」（subset of）'],
  ['∪', '和集合（union）'],
  ['∩', '積集合・共通部分（intersection）'],
  ['∅', '空集合：要素を一つも含まない集合（empty set）'],
];

function addSymTips() {
  // nav, headings, tip-box etc のテキストを走査してツールチップを付与
  var selectors = ['h3', 'h4', '.nav-sub', '.nav-ch', '.tip-box', '.formula-box', '.example-box', '.proof-box', '.important-box', '.note', 'p', 'li'];
  selectors.forEach(function(sel) {
    document.querySelectorAll(sel).forEach(function(el) {
      // MathJax要素を壊さないようにテキストノードのみ操作
      Array.from(el.childNodes).forEach(function(node) {
        if (node.nodeType !== 3) return; // text node only
        var text = node.textContent;
        var matched = false;
        symbolAnnotations.forEach(function(ann) {
          if (!matched && text.includes(ann[0])) {
            matched = true;
            var span = document.createElement('span');
            span.innerHTML = text.replace(
              ann[0],
              '<span class="sym-tip" data-tip="' + ann[1] + '">' + ann[0] + '</span>'
            );
            node.parentNode.replaceChild(span, node);
          }
        });
      });
    });
  });
}

// ========== MathJax 完了後に実行 ==========
window.addEventListener('load', function() {
  if (window.MathJax && MathJax.typesetPromise) {
    MathJax.typesetPromise().then(function() {
      addSymTips();
    });
  } else {
    addSymTips();
  }
});
</script>

