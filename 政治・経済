let currentQ = 0;
let score = 0;
let answered = new Array(questions.length).fill(false);
let correct = new Array(questions.length).fill(false);

function buildQuiz() {
  const container = document.getElementById('questions');
  container.innerHTML = '';
  questions.forEach((q, i) => {
    const div = document.createElement('div');
    div.className = 'q-block' + (i === 0 ? ' active' : '');
    div.id = 'q' + i;
    const labels = ['A', 'B', 'C', 'D'];
    div.innerHTML = `
      <div class="q-num">問 ${i+1} / ${questions.length}</div>
      <div class="q-text">${q.q}</div>
      <div class="options" id="opts${i}">
        ${q.opts.map((o, j) => `
          <button class="opt-btn" onclick="answer(${i},${j})">
            <span class="opt-label">${labels[j]}</span>
            ${o}
          </button>
        `).join('')}
      </div>
      <div class="explanation" id="exp${i}"><strong>解説：</strong> ${q.exp}</div>
      <div class="q-nav">
        <button class="nav-btn" onclick="prevQ()" ${i===0?'disabled':''}>← 前へ</button>
        <button class="nav-btn primary" id="nextBtn${i}" onclick="${i===questions.length-1?'showResult()':'nextQ()'}" style="display:none">${i===questions.length-1?'結果を見る':'次へ →'}</button>
      </div>
    `;
    container.appendChild(div);
  });
  updateProgress();
}

function answer(qIdx, optIdx) {
  if (answered[qIdx]) return;
  answered[qIdx] = true;
  const btns = document.querySelectorAll(`#opts${qIdx} .opt-btn`);
  const isCorrect = optIdx === questions[qIdx].ans;
  if (isCorrect) { score++; correct[qIdx] = true; }
  btns.forEach((btn, j) => {
    btn.disabled = true;
    if (j === questions[qIdx].ans) btn.classList.add('correct');
    else if (j === optIdx && !isCorrect) btn.classList.add('wrong');
  });
  document.getElementById('exp' + qIdx).classList.add('show');
  document.getElementById('nextBtn' + qIdx).style.display = 'inline-flex';
  updateProgressBadge();
}

function nextQ() {
  if (currentQ < questions.length - 1) {
    document.getElementById('q' + currentQ).classList.remove('active');
    currentQ++;
    document.getElementById('q' + currentQ).classList.add('active');
    updateProgress();
    window.scrollTo({top: document.querySelector('.quiz-container').offsetTop - 80, behavior: 'smooth'});
  }
}

function prevQ() {
  if (currentQ > 0) {
    document.getElementById('q' + currentQ).classList.remove('active');
    currentQ--;
    document.getElementById('q' + currentQ).classList.add('active');
    updateProgress();
  }
}

function updateProgress() {
  const pct = ((currentQ + 1) / questions.length) * 100;
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('quizProgress').textContent = `問${currentQ+1} / 全${questions.length}問`;
}

function updateProgressBadge() {
  const done = answered.filter(Boolean).length;
  document.getElementById('totalScore').textContent = `${score}/${done}`;
}

function showResult() {
  document.querySelectorAll('.q-block').forEach(b => b.classList.remove('active'));
  const panel = document.getElementById('resultPanel');
  panel.classList.add('show');
  const pct = Math.round(score / questions.length * 100);
  document.getElementById('resultScore').textContent = `${score} / ${questions.length}`;
  let grade, color, label;
  if (pct >= 90) { grade = 'S'; color = '#f0a832'; label = '🏆 合格確実！最高レベル達成！' }
  else if (pct >= 75) { grade = 'A'; color = '#3ecf8e'; label = '✨ 合格圏内！あと少し！' }
  else if (pct >= 60) { grade = 'B'; color = '#4a9eff'; label = '📚 もう少し！苦手分野を復習しよう' }
  else if (pct >= 40) { grade = 'C'; color = '#e8443a'; label = '💪 基礎からしっかり復習しよう！' }
  else { grade = 'D'; color = '#9ba8bb'; label = '📖 各タブの内容を再確認してから挑戦！' }
  document.getElementById('resultLabel').textContent = label;
  document.getElementById('gradeBadge').textContent = `ランク ${grade}（正答率 ${pct}%）`;
  document.getElementById('gradeBadge').style.background = color + '22';
  document.getElementById('gradeBadge').style.color = color;
  document.getElementById('gradeBadge').style.border = `1px solid ${color}44`;
  document.getElementById('totalScore').textContent = `${score}/${questions.length}`;
  document.getElementById('progressFill').style.width = '100%';
}

function resetQuiz() {
  currentQ = 0; score = 0;
  answered = new Array(questions.length).fill(false);
  correct = new Array(questions.length).fill(false);
  document.getElementById('resultPanel').classList.remove('show');
  document.getElementById('totalScore').textContent = '-';
  buildQuiz();
}

buildQuiz();
</script>
